{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lluiseriksson.github.io/physmath-knowledge-tree/curation/record.schema.json",
  "title": "PhysMath source curation record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "processed",
    "status",
    "review",
    "source",
    "retention",
    "summary",
    "promoted",
    "quarantined",
    "discarded",
    "verification_queue"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^curation\\.[a-z0-9_]+$"},
    "schema_version": {"const": "1.2.0"},
    "processed": {"type": "string", "format": "date"},
    "status": {"type": "string", "enum": ["draft", "curated", "reviewed"]},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {"type": "string", "enum": ["pending", "approved", "changes_requested"]},
        "reviewer": {"type": "string", "minLength": 2},
        "reviewed_at": {"type": "string", "format": "date"},
        "notes": {"type": "string", "minLength": 4}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "approved"}}},
          "then": {"required": ["reviewer", "reviewed_at"]}
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "media_type", "sha256", "bytes"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "media_type": {"type": "string", "enum": ["text/plain", "text/markdown", "image/png"]},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "bytes": {"type": "integer", "minimum": 0},
        "lines": {"type": "integer", "minimum": 1},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"media_type": {"pattern": "^text/"}}},
          "then": {"required": ["lines"]}
        },
        {
          "if": {"properties": {"media_type": {"const": "image/png"}}},
          "then": {"required": ["width", "height"]}
        }
      ]
    },
    "retention": {
      "type": "string",
      "enum": ["retain-original", "delete-after-user-review", "deleted-after-review"]
    },
    "summary": {"type": "string", "minLength": 20},
    "promoted": {"type": "array", "items": {"$ref": "#/$defs/decision"}},
    "quarantined": {"type": "array", "items": {"$ref": "#/$defs/decision"}},
    "discarded": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "reason"],
        "properties": {
          "category": {"type": "string", "minLength": 3},
          "reason": {"type": "string", "minLength": 12},
          "examples": {"type": "array", "items": {"type": "string", "minLength": 2}}
        }
      }
    },
    "verification_queue": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "request", "reason"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_\\.]+$"},
          "request": {"type": "string", "minLength": 12},
          "reason": {"type": "string", "minLength": 12},
          "status": {"type": "string", "enum": ["pending", "verified", "rejected"]}
        }
      }
    }
  },
  "$defs": {
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_line", "end_line"],
      "properties": {
        "start_line": {"type": "integer", "minimum": 1},
        "end_line": {"type": "integer", "minimum": 1}
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height", "label"],
      "properties": {
        "x": {"type": "integer", "minimum": 0},
        "y": {"type": "integer", "minimum": 0},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "label": {"type": "string", "minLength": 3},
        "caption": {"type": "string", "minLength": 8},
        "alt_text": {"type": "string", "minLength": 8},
        "transformations": {"type": "array", "items": {"type": "string", "minLength": 2}}
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {"type": "string", "enum": ["graph_node", "graph_edge", "research_move", "document"]},
        "value": {"type": "string", "minLength": 2}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "classification", "rationale", "destinations"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_\\.]+$"},
        "title": {"type": "string", "minLength": 3},
        "classification": {"type": "string", "enum": ["formal", "literature", "heuristic", "speculative"]},
        "rationale": {"type": "string", "minLength": 12},
        "source_ranges": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/range"}},
        "source_regions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/region"}},
        "destinations": {"type": "array", "items": {"$ref": "#/$defs/destination"}}
      },
      "anyOf": [
        {"required": ["source_ranges"]},
        {"required": ["source_regions"]}
      ]
    }
  }
}
