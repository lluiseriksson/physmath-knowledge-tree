{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lluiseriksson.github.io/physmath-knowledge-tree/curation/record.schema.json",
  "title": "PhysMath source curation record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "processed",
    "status",
    "source",
    "retention",
    "summary",
    "promoted",
    "quarantined",
    "discarded",
    "verification_queue"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^curation\\.[a-z0-9_]+$"
    },
    "schema_version": {
      "type": "string"
    },
    "processed": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "curated", "reviewed"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "media_type", "sha256", "bytes"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "media_type": {"type": "string", "minLength": 3},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "bytes": {"type": "integer", "minimum": 0},
        "lines": {"type": "integer", "minimum": 1},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      }
    },
    "retention": {
      "type": "string",
      "enum": [
        "retain-original",
        "delete-after-user-review",
        "deleted-after-review"
      ]
    },
    "summary": {"type": "string", "minLength": 20},
    "promoted": {
      "type": "array",
      "items": {"$ref": "#/$defs/decision"}
    },
    "quarantined": {
      "type": "array",
      "items": {"$ref": "#/$defs/decision"}
    },
    "discarded": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "reason"],
        "properties": {
          "category": {"type": "string", "minLength": 3},
          "reason": {"type": "string", "minLength": 12},
          "examples": {
            "type": "array",
            "items": {"type": "string", "minLength": 2}
          }
        }
      }
    },
    "verification_queue": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "request", "reason"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_\\.]+$"},
          "request": {"type": "string", "minLength": 12},
          "reason": {"type": "string", "minLength": 12}
        }
      }
    }
  },
  "$defs": {
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_line", "end_line"],
      "properties": {
        "start_line": {"type": "integer", "minimum": 1},
        "end_line": {"type": "integer", "minimum": 1}
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["graph_node", "graph_edge", "research_move", "document"]
        },
        "value": {"type": "string", "minLength": 2}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "classification",
        "rationale",
        "source_ranges",
        "destinations"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_\\.]+$"},
        "title": {"type": "string", "minLength": 3},
        "classification": {
          "type": "string",
          "enum": ["formal", "literature", "heuristic", "speculative"]
        },
        "rationale": {"type": "string", "minLength": 12},
        "source_ranges": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/range"}
        },
        "destinations": {
          "type": "array",
          "items": {"$ref": "#/$defs/destination"}
        }
      }
    }
  }
}
