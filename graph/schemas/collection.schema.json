{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lluiseriksson.github.io/physmath-knowledge-tree/schemas/collection.schema.json",
  "title": "PhysMath curated collection list",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "title",
      "description",
      "nodes"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^collection\\.[a-z0-9_]+$"
      },
      "title": {
        "type": "string",
        "minLength": 2
      },
      "description": {
        "type": "string",
        "minLength": 12
      },
      "nodes": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string"
        }
      }
    }
  }
}
