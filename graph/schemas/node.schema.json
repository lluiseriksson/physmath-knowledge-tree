{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PhysMath node list",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "kind", "title", "summary", "confidence", "tags", "lean", "questions"],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z]+\\.[a-z0-9_\\.]+$" },
      "kind": {
        "type": "string",
        "enum": ["domain", "theory", "concept", "theorem", "formula", "method", "problem", "bridge"]
      },
      "title": { "type": "string" },
      "summary": { "type": "string" },
      "confidence": {
        "type": "string",
        "enum": ["formal", "literature", "heuristic", "speculative"]
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "lean": {
        "type": "object",
        "required": ["imports", "declarations", "targets"],
        "properties": {
          "imports": { "type": "array", "items": { "type": "string" } },
          "declarations": { "type": "array", "items": { "type": "string" } },
          "targets": { "type": "array", "items": { "type": "string" } }
        }
      },
      "questions": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}

