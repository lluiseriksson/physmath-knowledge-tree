{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lluiseriksson.github.io/physmath-knowledge-tree/schemas/node.schema.json",
  "title": "PhysMath knowledge node list",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "kind",
      "title",
      "summary",
      "confidence",
      "tags",
      "lean",
      "questions",
      "references"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^(domain|problem|bridge)\\.[a-z0-9_\\.]+$"
      },
      "kind": {
        "type": "string",
        "enum": [
          "domain",
          "problem",
          "bridge"
        ]
      },
      "title": {
        "type": "string",
        "minLength": 2,
        "maxLength": 160
      },
      "summary": {
        "type": "string",
        "minLength": 20,
        "maxLength": 600
      },
      "confidence": {
        "type": "string",
        "enum": [
          "formal",
          "literature",
          "heuristic",
          "speculative"
        ]
      },
      "status": {
        "type": "string",
        "enum": [
          "unsolved",
          "solved"
        ]
      },
      "tags": {
        "type": "array",
        "minItems": 2,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "lean": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "imports",
          "declarations",
          "targets"
        ],
        "properties": {
          "imports": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "declarations": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "targets": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 8
            }
          }
        }
      },
      "questions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 8
        }
      },
      "references": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "label",
            "url",
            "type",
            "scope"
          ],
          "properties": {
            "label": {
              "type": "string",
              "minLength": 2
            },
            "url": {
              "type": "string",
              "pattern": "^https://"
            },
            "type": {
              "type": "string",
              "enum": [
                "official",
                "paper",
                "book",
                "documentation",
                "survey"
              ]
            },
            "scope": {
              "type": "string",
              "enum": [
                "claim",
                "context",
                "formalization"
              ]
            }
          }
        },
        "minItems": 1
      }
    },
    "allOf": [
      {
        "if": {
          "properties": {
            "kind": {
              "const": "problem"
            }
          }
        },
        "then": {
          "required": [
            "status"
          ]
        }
      },
      {
        "if": {
          "required": [
            "status"
          ]
        },
        "then": {
          "properties": {
            "kind": {
              "const": "problem"
            }
          }
        }
      }
    ]
  }
}
