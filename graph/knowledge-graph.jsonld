      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/bridge.appendix_f_rate_budget_split",
      "@type": "pm:Bridge",
      "stableId": "bridge.appendix_f_rate_budget_split",
      "name": "Appendix-F rate-budget decomposition",
      "description": "The first-activity decay rate can be split into residual target decay and a reserved leaf-summation budget. In the canonical bookkeeping, (kappa - kappa-zero - 2) equals (kappa - 3 kappa-zero - 3) plus (2 kappa-zero + 1).",
      "kind": "bridge",
      "confidence": "formal",
      "keywords": [
        "appendix-f",
        "decay-rate",
        "leaf-budget",
        "modified-metric",
        "smallness"
      ],
      "questions": [
        "Can the spare unit of rate absorb an active-cardinality tilt without weakening the target exponent?",
        "Which source constants determine whether the geometric-series window is nonempty in four dimensions?"
      ],
      "leanImports": [
        "Mathlib.Data.Real.Basic",
        "PhysMathKnowledgeTree.Formal.Microtheorems"
      ],
      "leanDeclarations": [
        "appendixFRateBudgetIdentity"
      ],
      "leanTargets": [
        "Derive a geometric order bound with ratio 4 * C2^2 * epsilon while keeping every smallness condition explicit.",
        "Parameterize how much decay is reserved for target extraction, leaf moments, cardinality tilts and convergence margins.",
        "Prove the exact algebraic rate identity and monotonicity corollaries under nonnegative residual rate."
      ],
      "citation": [
        {
          "@type": "schema:CreativeWork",
          "name": "J. Dimock — The Renormalization Group According to Balaban II",
          "url": "https://arxiv.org/abs/1212.5562",
          "referenceType": "paper",
          "referenceScope": "claim"
        }
      ]
    },
