      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/bridge.rooted_leaf_factorial_moments",
      "@type": "pm:Bridge",
      "stableId": "bridge.rooted_leaf_factorial_moments",
      "name": "Rooted leaf elimination by factorial moments",
      "description": "Orient a tree from a marked root and sum polymer assignments from leaves upward. Rooted and parent-child incompatibility moments absorb child metric powers, yielding a fixed-tree bound governed by factorials of child counts before the remaining tree shapes are summed.",
      "kind": "bridge",
      "confidence": "formal",
      "keywords": [
        "cluster-bound",
        "factorial-moments",
        "leaf-elimination",
        "parent-child",
        "rooted-tree"
      ],
      "questions": [
        "Can a parent-dependent moment kernel improve the uniform moment constant?",
        "Can parent-metric normalization expose a vertexwise walk theorem without introducing a volume-dependent global sum?",
        "Which rooted-tree enumeration gives the sharpest normalized bound compatible with the local kernel?"
      ],
