      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/bridge.conditional_mutual_information_recovery",
      "@type": "pm:Bridge",
      "stableId": "bridge.conditional_mutual_information_recovery",
      "name": "Conditional mutual information to uniform recovery",
      "description": "Small quantum conditional mutual information controls reconstruction of a tripartite state from a marginal by a channel acting on the conditioning system. The useful research discipline is the uniform quantifier order: one recovery map should work for every state in the chosen code or extension class.",
      "kind": "bridge",
      "confidence": "literature",
      "keywords": [
        "conditional-mutual-information",
        "markov-chain",
        "recovery-map",
        "uniformity"
      ],
      "questions": [
        "Can a collar-conditioned recovery channel be made uniform over a finite low-energy code while preserving entanglement with a reference?"
      ],
      "leanImports": [
        "Mathlib"
      ],
      "leanDeclarations": [],
      "leanTargets": [
        "Keep any split/type-III AQFT extension conditional until its operator-algebraic recovery inequality is sourced.",
        "State a finite-dimensional recovery interface with an explicit reference system and uniform channel quantifiers."
      ],
      "citation": [
