      "@type": "pm:Bridge",
      "stableId": "bridge.rooted_tree_catalan_closure",
      "name": "Exact Catalan closure of rooted child-factorial tree sums",
      "description": "For labelled trees on n+1 vertices rooted at a fixed label, the sum of the products of child-count factorials equals n! times the nth Catalan number. This replaces the coarse Catalan bound 4^n by an exact generating function and yields a square-root closure for the second-gas majorant.",
      "kind": "bridge",
      "confidence": "formal",
      "keywords": [
        "catalan",
        "cluster-bound",
        "generating-function",
        "rooted-tree"
      ],
      "questions": [
