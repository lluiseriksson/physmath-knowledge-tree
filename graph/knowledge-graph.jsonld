      ],
      "leanDeclarations": [
        "childFactorialProductCongr"
      ],
      "leanTargets": [
        "Derive the closed majorant B = (1 - sqrt(1 - 4 M^2 epsilon)) / (2 M) and its quadratic fixed-point equation.",
        "Prove the exact normalized rooted child-factorial tree sum equals the Catalan number under the repository tree convention."
      ],
