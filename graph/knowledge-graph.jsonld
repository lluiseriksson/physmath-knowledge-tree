    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.localize_homotopy",
      "@type": "pm:ResearchMove",
      "stableId": "move.localize_homotopy",
      "name": "Localize a homotopy and expose the boundary defect",
      "description": "Sandwich a global homotopy by a support projector and rewrite the failure of the contraction identity as commutators with that projector.",
      "goodFor": [
