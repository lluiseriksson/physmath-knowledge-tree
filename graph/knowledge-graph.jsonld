    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.audit_information_loss",
      "@type": "pm:ResearchMove",
      "stableId": "move.audit_information_loss",
      "name": "Audit information loss",
      "description": "For every abstraction or majorant, list the target, locality, signs, edges and scale data it forgets, then test whether the desired conclusion still mentions them.",
      "goodFor": [
        "bridge.target_erasure_diagnostic",
        "bridge.ward_defect_weight_variation",
        "domain.polymer_cluster_expansions"
      ],
      "output": "retained-versus-forgotten data table, circularity check and smallest finite counterexample",
      "risks": [
        "Applied indiscriminately, the audit can reject coarse bounds that are valid after the relevant structure has already been consumed."
      ],
      "leanTest": "Prove an exact factorization of the coarse object and exhibit two inputs with the same coarse data but different target-sensitive statistics."
    },
    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.cancel_before_majorizing",
      "@type": "pm:ResearchMove",
      "stableId": "move.cancel_before_majorizing",
      "name": "Cancel before majorizing",
      "description": "Preserve signed, graded or symmetry-related contributions long enough to apply an exact or defective Ward identity before taking norms and triangle inequalities.",
      "goodFor": [
        "bridge.cluster_expansion_with_holes",
        "bridge.ward_defect_weight_variation",
        "problem.uniform_yang_mills_rg_activity"
      ],
      "output": "a decomposition into an exact sector, a quantified defect and a residual activity profile",
      "risks": [
        "An abstract differential may not act on the actual measure or regulator.",
        "Taking absolute values too early destroys the cancellation being tested."
      ],
      "leanTest": "Prove the finite weighted Ward identity and derive a norm bound controlled only by the weight variation."
    },
    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.categorify",
      "@type": "pm:ResearchMove",
      "stableId": "move.categorify",
      "name": "Categorify",
      "description": "Replace sets or equations by objects, morphisms, functors and natural transformations.",
      "goodFor": [
        "domain.algebraic_geometry",
        "problem.hodge_conjecture",
        "problem.p_vs_np"
      ],
      "output": "functorial dictionary or universal property",
      "risks": [
        "The categorical lift may hide the original hard estimate."
      ],
      "leanTest": "State the relevant universal property in a small category."
    },
    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.close_exact_generating_function",
      "@type": "pm:ResearchMove",
      "stableId": "move.close_exact_generating_function",
      "name": "Close the exact generating function",
      "description": "Replace a coarse coefficient bound by the exact combinatorial enumeration, then sum its known generating function and retain the resulting stability information.",
      "goodFor": [
        "bridge.rooted_leaf_factorial_moments",
        "bridge.rooted_tree_catalan_closure",
        "domain.polymer_cluster_expansions"
      ],
      "output": "closed square-root majorant, exact convergence boundary and sensitivity bound",
      "risks": [
        "The exact enumeration may use a different rooting, labelling or tree class from the analytic coefficient actually present."
      ],
      "leanTest": "Enumerate labelled rooted trees for n up to five and compare the normalized child-factorial sum with the Catalan number."
    },
    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.condition_on_separator",
      "@type": "pm:ResearchMove",
      "stableId": "move.condition_on_separator",
      "name": "Condition on a separator",
      "description": "Insert a collar or separator, condition on its variables and test whether the remaining precision or graph decomposes into independent components.",
      "goodFor": [
        "bridge.conditional_mutual_information_recovery",
        "bridge.gaussian_covariance_collar",
        "bridge.gaussian_precision_markov_blanket"
      ],
      "output": "exact conditional factorization or an explicit cross-block defect localized at the separator",
      "risks": [
