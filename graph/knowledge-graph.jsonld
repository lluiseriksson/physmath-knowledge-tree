      ],
      "leanTest": "Prove the ungraded matrix identity first, then add a finite cochain complex where the commutator support is computed explicitly."
    },
    {
      "@id": "https://lluiseriksson.github.io/physmath-knowledge-tree/id/move.normalize_parent_kernel",
      "@type": "pm:ResearchMove",
      "stableId": "move.normalize_parent_kernel",
