{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/physmath/yang-mills-pack.schema.json",
  "title": "Yang–Mills Agent Pack Manifest",
  "type": "object",
  "required": [
    "pack_version",
    "target_repository",
    "baseline",
    "upgrade_version",
    "yang_mills_repository",
    "entrypoints",
    "machine_data",
    "quality_gates",
    "guardrails"
  ],
  "properties": {
    "pack_version": {
      "type": "string"
    },
    "target_repository": {
      "const": "lluiseriksson/physmath-knowledge-tree"
    },
    "upgrade_version": {
      "type": "string"
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "quality_gates": {
      "type": "array",
      "minItems": 10
    },
    "guardrails": {
      "type": "array",
      "minItems": 5
    }
  },
  "additionalProperties": true
}
